# Copy this file to `.env` and fill in your own values.

# Which Ollama model to use for chat/summaries/explanations
OLLAMA_MODEL=llama3.2:1b

# The URL where your local Ollama instance is running
OLLAMA_URL=http://localhost:11434

# Port the Express server listens on
PORT=5000

# Comma-separated list of origins allowed to call this server.
# The extension itself talks to the backend via background.js (no page
# origin), but keep this open to "*" during local development.
CORS_ORIGIN=*
